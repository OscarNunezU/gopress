# gopress environment variables
# Copy this file to .env and adjust to your environment.
# .env is gitignored — never commit secrets.

# HTTP port gopress listens on.
GOPRESS_PORT=3000

# Number of Chromium instances in the pool.
# Increase for higher concurrency (each instance uses ~150MB RAM).
GOPRESS_POOL_SIZE=4

# Number of conversions per Chromium instance before it is restarted.
# Lower values improve memory stability at the cost of restart overhead.
GOPRESS_MAX_CONVERSIONS=100

# Pending-job queue buffer size.
# 0 (default) = auto, which is GOPRESS_POOL_SIZE * 4.
# Increase if you observe 503s under burst traffic.
GOPRESS_QUEUE_DEPTH=0

# Absolute path to the Chrome/Chromium binary.
# Docker image default: /usr/bin/chrome
# Ubuntu/Debian:        /usr/bin/google-chrome  or  /usr/bin/chromium-browser
# macOS (homebrew):     /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_BIN_PATH=/usr/bin/google-chrome

# OpenTelemetry OTLP/gRPC endpoint for distributed tracing.
# Leave empty to disable tracing (noop tracer, zero overhead).
# Example with local Jaeger: http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# API key for POST /pdf authentication (Bearer token).
# Leave empty to disable authentication (suitable for internal/dev deployments
# protected at the network layer). When set, requests must include:
#   Authorization: Bearer <your-key>
# Minimum length: 16 characters.
GOPRESS_API_KEY=

# Rate limiting for POST /pdf (token-bucket algorithm).
# GOPRESS_RATE_LIMIT: steady-state requests per second (float). 0 = disabled.
# GOPRESS_RATE_BURST: maximum burst above the rate limit. Defaults to 1.
# Example: GOPRESS_RATE_LIMIT=10 GOPRESS_RATE_BURST=20 allows 10 req/s sustained
# with bursts up to 20, returning 429 with Retry-After: 1 when exceeded.
GOPRESS_RATE_LIMIT=0
GOPRESS_RATE_BURST=0
