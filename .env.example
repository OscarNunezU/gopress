# gopress environment variables
# Copy this file to .env and adjust to your environment.
# .env is gitignored — never commit secrets.

# HTTP port gopress listens on.
GOPRESS_PORT=3000

# Number of Chromium instances in the pool.
# Increase for higher concurrency (each instance uses ~150MB RAM).
GOPRESS_POOL_SIZE=4

# Number of conversions per Chromium instance before it is restarted.
# Lower values improve memory stability at the cost of restart overhead.
GOPRESS_MAX_CONVERSIONS=100

# Absolute path to the Chrome/Chromium binary.
# Docker image default: /usr/bin/chrome
# Ubuntu/Debian:        /usr/bin/google-chrome  or  /usr/bin/chromium-browser
# macOS (homebrew):     /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_BIN_PATH=/usr/bin/google-chrome

# OpenTelemetry OTLP/gRPC endpoint for distributed tracing.
# Leave empty to disable tracing (noop tracer, zero overhead).
# Example with local Jaeger: http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
